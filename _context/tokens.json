{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$meta": {
    "name": "Buscou Viajou Design Tokens",
    "version": "1.0.0",
    "derivedFrom": "Manual da Marca - Buscou Viajou v1 (12-page PDF)",
    "note": "Itens marcados com 'inferred: true' não estão no manual original e foram inferidos para produto digital."
  },
  "color": {
    "brand": {
      "navy":  { "$value": "#0B2A43", "$type": "color", "$description": "Primária oficial. Confiança, tecnologia, segurança." },
      "green": { "$value": "#2B9366", "$type": "color", "$description": "Primária oficial. Movimento, inovação, crescimento." }
    },
    "neutral": {
      "white":      { "$value": "#FFFFFF", "$type": "color" },
      "black":      { "$value": "#000000", "$type": "color" },
      "bg":         { "$value": "#F1F5F6", "$type": "color", "inferred": true, "$description": "Background blueprint." },
      "grid-line":  { "$value": "#E1E7EA", "$type": "color", "inferred": true, "$description": "Linha do grid de fundo." }
    },
    "navy-scale": {
      "50":  { "$value": "#E7ECF0", "$type": "color", "inferred": true },
      "100": { "$value": "#CED9E1", "$type": "color", "inferred": true },
      "200": { "$value": "#9DB3C3", "$type": "color", "inferred": true },
      "300": { "$value": "#6C8DA6", "$type": "color", "inferred": true },
      "400": { "$value": "#3B6788", "$type": "color", "inferred": true },
      "500": { "$value": "#0B2A43", "$type": "color", "$description": "Base oficial." },
      "600": { "$value": "#092336", "$type": "color", "inferred": true },
      "700": { "$value": "#071B2A", "$type": "color", "inferred": true },
      "800": { "$value": "#04131D", "$type": "color", "inferred": true },
      "900": { "$value": "#020810", "$type": "color", "inferred": true }
    },
    "green-scale": {
      "50":  { "$value": "#E4F4EC", "$type": "color", "inferred": true },
      "100": { "$value": "#C9E9D9", "$type": "color", "inferred": true },
      "200": { "$value": "#95D3B3", "$type": "color", "inferred": true },
      "300": { "$value": "#60BC8C", "$type": "color", "inferred": true },
      "400": { "$value": "#3FA675", "$type": "color", "inferred": true },
      "500": { "$value": "#2B9366", "$type": "color", "$description": "Base oficial." },
      "600": { "$value": "#237652", "$type": "color", "inferred": true },
      "700": { "$value": "#1A583E", "$type": "color", "inferred": true },
      "800": { "$value": "#123B29", "$type": "color", "inferred": true },
      "900": { "$value": "#091D14", "$type": "color", "inferred": true }
    },
    "semantic": {
      "success": { "$value": "{color.brand.green}",  "$type": "color" },
      "info":    { "$value": "{color.brand.navy}",   "$type": "color" },
      "warning": { "$value": "#E0A23B", "$type": "color", "inferred": true },
      "danger":  { "$value": "#C64343", "$type": "color", "inferred": true }
    },
    "text": {
      "primary":   { "$value": "{color.brand.navy}",   "$type": "color" },
      "secondary": { "$value": "rgba(11, 42, 67, 0.72)", "$type": "color", "inferred": true },
      "accent":    { "$value": "{color.brand.green}",  "$type": "color" },
      "inverse":   { "$value": "{color.neutral.white}", "$type": "color" },
      "placeholder": { "$value": "rgba(11, 42, 67, 0.48)", "$type": "color", "inferred": true }
    }
  },
  "font": {
    "family": {
      "heading": {
        "$value": "Gotham, Poppins, 'Helvetica Neue', Arial, sans-serif",
        "$type": "fontFamily",
        "$description": "Gotham é a oficial; Poppins é fallback open-source."
      },
      "body": {
        "$value": "Hind, Poppins, 'Helvetica Neue', Arial, sans-serif",
        "$type": "fontFamily",
        "$description": "Hind é declarada; Poppins aparece no specimen — ver validação."
      }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight", "inferred": true },
      "semibold": { "$value": 600, "$type": "fontWeight", "inferred": true },
      "bold":     { "$value": 700, "$type": "fontWeight" },
      "black":    { "$value": 900, "$type": "fontWeight", "inferred": true }
    },
    "size": {
      "display": { "$value": "3.5rem",   "$type": "dimension", "inferred": true },
      "h1":      { "$value": "2.5rem",   "$type": "dimension", "inferred": true },
      "h2":      { "$value": "2rem",     "$type": "dimension", "inferred": true },
      "h3":      { "$value": "1.5rem",   "$type": "dimension", "inferred": true },
      "h4":      { "$value": "1.25rem",  "$type": "dimension", "inferred": true },
      "body-lg": { "$value": "1.125rem", "$type": "dimension", "inferred": true },
      "body":    { "$value": "1rem",     "$type": "dimension", "inferred": true },
      "body-sm": { "$value": "0.875rem", "$type": "dimension", "inferred": true },
      "caption": { "$value": "0.75rem",  "$type": "dimension", "inferred": true }
    },
    "lineHeight": {
      "tight":   { "$value": 1.1,  "inferred": true },
      "snug":    { "$value": 1.25, "inferred": true },
      "normal":  { "$value": 1.5,  "inferred": true },
      "relaxed": { "$value": 1.75, "inferred": true }
    }
  },
  "space": {
    "0": { "$value": "0",      "$type": "dimension" },
    "1": { "$value": "0.25rem","$type": "dimension", "inferred": true },
    "2": { "$value": "0.5rem", "$type": "dimension", "inferred": true },
    "3": { "$value": "0.75rem","$type": "dimension", "inferred": true },
    "4": { "$value": "1rem",   "$type": "dimension", "inferred": true },
    "5": { "$value": "1.5rem", "$type": "dimension", "inferred": true },
    "6": { "$value": "2rem",   "$type": "dimension", "inferred": true },
    "7": { "$value": "3rem",   "$type": "dimension", "inferred": true },
    "8": { "$value": "4rem",   "$type": "dimension", "inferred": true },
    "9": { "$value": "6rem",   "$type": "dimension", "inferred": true }
  },
  "radius": {
    "none": { "$value": "0",      "$type": "dimension" },
    "sm":   { "$value": "4px",    "$type": "dimension", "inferred": true },
    "md":   { "$value": "8px",    "$type": "dimension", "inferred": true },
    "lg":   { "$value": "16px",   "$type": "dimension", "inferred": true },
    "pill": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm":    { "$value": "0 1px 2px rgba(11, 42, 67, 0.06)",   "$type": "shadow", "inferred": true },
    "md":    { "$value": "0 4px 12px rgba(11, 42, 67, 0.08)",  "$type": "shadow", "inferred": true },
    "lg":    { "$value": "0 12px 32px rgba(11, 42, 67, 0.12)", "$type": "shadow", "inferred": true },
    "focus": { "$value": "0 0 0 3px rgba(43, 147, 102, 0.35)", "$type": "shadow", "inferred": true }
  },
  "border": {
    "thin":  { "$value": "1px", "$type": "dimension" },
    "base":  { "$value": "2px", "$type": "dimension", "inferred": true },
    "thick": { "$value": "3px", "$type": "dimension" }
  },
  "grid": {
    "container": { "$value": "1200px", "$type": "dimension", "inferred": true },
    "columns":   { "$value": 12, "inferred": true },
    "gutter":    { "$value": "24px",   "$type": "dimension", "inferred": true }
  },
  "breakpoint": {
    "sm":  { "$value": "640px",  "$type": "dimension", "inferred": true },
    "md":  { "$value": "768px",  "$type": "dimension", "inferred": true },
    "lg":  { "$value": "1024px", "$type": "dimension", "inferred": true },
    "xl":  { "$value": "1280px", "$type": "dimension", "inferred": true },
    "2xl": { "$value": "1536px", "$type": "dimension", "inferred": true }
  },
  "motion": {
    "fast": { "$value": "150ms", "$type": "duration", "inferred": true },
    "base": { "$value": "250ms", "$type": "duration", "inferred": true },
    "slow": { "$value": "400ms", "$type": "duration", "inferred": true },
    "ease": { "$value": "cubic-bezier(0.2, 0.8, 0.2, 1)", "inferred": true }
  }
}
